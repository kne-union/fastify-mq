{
  "name": "@kne/fastify-mq",
  "version": "0.1.1",
  "description": "Reliable message queue plugin for Fastify based on PostgreSQL, supporting at-least-once delivery, DLQ, delayed messages, priority, tracing and Kafka migration",
  "main": "index.js",
  "scripts": {
    "init": "husky",
    "build:md": "npx @kne/md-doc",
    "start:md": "npx @kne/md-doc --watch",
    "prettier": "prettier --config .prettierrc --write '{libs/**/*,index}.{js,jsx,ts,tsx,json,css,scss}'",
    "lint-staged": "npx lint-staged",
    "test": "mocha --exit test/**/*.test.js",
    "test:coverage": "nyc --reporter=html --reporter=text mocha --exit test/**/*.test.js"
  },
  "lint-staged": {
    "{libs/**/*,index}.{js,jsx,ts,tsx,json,css,scss}": [
      "prettier --config .prettierrc --write",
      "git add"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts",
    "libs",
    "grafana"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kne-union/fastify-mq.git"
  },
  "keywords": [
    "fastify",
    "message-queue",
    "mq",
    "postgresql",
    "dlq",
    "dead-letter",
    "reliable-delivery",
    "at-least-once",
    "delayed-message",
    "priority-queue",
    "message-tracing",
    "kafka-migration"
  ],
  "author": "linzp",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kne-union/fastify-mq/issues"
  },
  "homepage": "https://github.com/kne-union/fastify-mq#readme",
  "peerDependencies": {
    "@kne/fastify-namespace": "*",
    "@kne/fastify-sequelize": "*",
    "fastify-plugin": ">=5"
  },
  "devDependencies": {
    "@fastify/env": "^5.0.2",
    "@kne/fastify-namespace": "^1.2.1",
    "@kne/fastify-sequelize": "^3.0.6",
    "chai": "^6.2.2",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "husky": "^9.0.11",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.3",
    "nyc": "^17.1.0",
    "prettier": "^3.2.5",
    "sqlite3": "^5.1.7",
    "typescript": "^6.0.3"
  }
}
